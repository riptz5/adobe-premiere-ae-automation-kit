PORT=8787

# LLM (Ollama by default — no API key needed for local use)
# Recommended for Apple Silicon 16 GB: llama3.1:8b (Q4_K_M, ~5 GB)
LLM_MODEL=llama3.1:8b
LLM_BASE_URL=http://127.0.0.1:11435/v1
LLM_ENABLED=true

# Optional: restrict CORS to a specific origin (defaults to http://localhost:8787)
# CORS_ORIGIN=http://localhost:8787

# Optional: protect POST /v1/config/local with an API key
# ADMIN_KEY=change-me-in-production
