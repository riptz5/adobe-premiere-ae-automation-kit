PORT=8787

# ─── LLM (Ollama, local — no API key needed) ───────────────────────────────────
# Recommended for Apple Silicon 16 GB: llama3.1:8b (Q4_K_M, ~5 GB unified memory)
LLM_MODEL=llama3.1:8b
LLM_BASE_URL=http://127.0.0.1:11435/v1
LLM_ENABLED=true

# ─── CORS / Security ───────────────────────────────────────────────────────────
# Restrict CORS to a specific origin (defaults to http://localhost:8787)
# CORS_ORIGIN=http://localhost:8787

# Protect POST /v1/config/local with an API key (optional — dev mode allows all)
# ADMIN_KEY=change-me-in-production

# ─── OSS Tool paths ────────────────────────────────────────────────────────────
# Leave blank to use system PATH. Set absolute paths to override.
#
# Premiere Pro replacement → Kdenlive + FFmpeg
# KDENLIVE_CLI_PATH=/usr/bin/kdenlive
# FFMPEG_PATH=/usr/local/bin/ffmpeg
#
# After Effects replacement → Blender VSE + Natron
# BLENDER_PATH=/Applications/Blender.app/Contents/MacOS/Blender
# NATRON_PATH=/usr/bin/natronrenderer
#
# Photoshop replacement → GIMP
# GIMP_PATH=/Applications/GIMP.app/Contents/MacOS/gimp
#
# DAW / Audio → Reaper
# REAPER_PATH=/Applications/REAPER64.app/Contents/MacOS/REAPER
#
# Python (for OSS adapters)
# PYTHON_PATH=/usr/local/bin/python3
